<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ImproveYourself.Maui.Views.HomePage"
             x:Name="ThisPage"
             BackgroundColor="{StaticResource ColorBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="22,16,22,30"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label x:Name="WelcomeLabel"
                           Text=""
                           Style="{StaticResource BodyLabelStyle}" />
                    <Label x:Name="GreetingNameLabel"
                           Text=""
                           Style="{StaticResource TitleLabelStyle}" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        WidthRequest="56"
                        HeightRequest="56"
                        Stroke="{StaticResource ColorBorder}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 28"
                        BackgroundColor="{StaticResource ColorSurfaceRaised}">
                    <Label x:Name="AvatarInitialLabel"
                           Text=""
                           FontFamily="OpenSansSemibold"
                           FontSize="20"
                           TextColor="{StaticResource ColorTextPrimary}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="CurrentStreakLabel"
                               Text=""
                               Style="{StaticResource BodyLabelStyle}" />
                        <Label x:Name="StreakValueLabel"
                               Text="0"
                               FontFamily="OpenSansSemibold"
                               FontSize="30"
                               TextColor="{StaticResource ColorTextPrimary}" />
                        <Label x:Name="DaysInRowLabel"
                               Text=""
                               Style="{StaticResource BodyLabelStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="MonthProgressLabel"
                               Text=""
                               Style="{StaticResource BodyLabelStyle}" />
                        <Label x:Name="MonthPercentLabel"
                               Text="0%"
                               FontFamily="OpenSansSemibold"
                               FontSize="30"
                               TextColor="{StaticResource ColorTextPrimary}" />
                        <Label x:Name="MonthHintLabel"
                               Text=""
                               Style="{StaticResource BodyLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Stroke="#8A4A23"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24"
                    BackgroundColor="{StaticResource ColorSurface}"
                    Padding="22"
                    Margin="0,4,0,0">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="ChallengeLeadLabel"
                           Text=""
                           TextColor="{StaticResource ColorAccent}"
                           FontFamily="OpenSansRegular"
                           FontSize="15" />
                    <Label x:Name="ChallengeTitleLabel"
                           Text=""
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label x:Name="ChallengeSubtitleLabel"
                           Text=""
                           Style="{StaticResource BodyLabelStyle}" />

                    <Label x:Name="PersonalizationLabel"
                           Text=""
                           TextColor="{StaticResource ColorAccent}"
                           FontFamily="OpenSansRegular"
                           FontSize="14"
                           LineBreakMode="WordWrap"
                           IsVisible="False" />

                    <ProgressBar x:Name="ChallengeProgressBar"
                                 Progress="0"
                                 ProgressColor="{StaticResource ColorAccent}"
                                 BackgroundColor="{StaticResource ColorFrame}"
                                 HeightRequest="10" />

                    <Label x:Name="RemainingDaysLabel"
                           Text=""
                           Style="{StaticResource BodyLabelStyle}" />

                    <Button x:Name="ChallengeButton"
                            Text=""
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,6,0,0"
                            Clicked="OnOpenChallengeClicked" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="12">
                <Button x:Name="StatisticsButton"
                        Text=""
                        Style="{StaticResource GhostButtonStyle}"
                        Clicked="OnOpenStatisticsClicked" />
                <Button x:Name="CalendarButton"
                        Text=""
                        Style="{StaticResource GhostButtonStyle}"
                        Clicked="OnOpenProfileClicked" />
            </VerticalStackLayout>

            <Button x:Name="SettingsButton"
                    Text=""
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource ColorAccent}"
                    FontFamily="OpenSansRegular"
                    FontSize="15"
                    HorizontalOptions="Start"
                    Clicked="OnOpenSettingsClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
