<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ImproveYourself.Maui.Views.SelfAssessmentPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource ColorBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="22,16,22,30"
                             Spacing="16">
            <HorizontalStackLayout x:Name="ProgressDots"
                                   Spacing="6"
                                   IsVisible="False">
                <Border WidthRequest="26"
                        HeightRequest="6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 999"
                        BackgroundColor="{StaticResource ColorSurfaceRaised}" />
                <Border WidthRequest="26"
                        HeightRequest="6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 999"
                        BackgroundColor="{StaticResource ColorSurfaceRaised}" />
                <Border WidthRequest="26"
                        HeightRequest="6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 999"
                        BackgroundColor="{StaticResource ColorSurfaceRaised}" />
                <Border WidthRequest="26"
                        HeightRequest="6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 999"
                        BackgroundColor="{StaticResource ColorAccent}" />
            </HorizontalStackLayout>

            <Border Style="{StaticResource CardBorderStyle}"
                    Padding="22">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="EyebrowLabel"
                           Text=""
                           TextColor="{StaticResource ColorAccent}"
                           FontFamily="OpenSansRegular"
                           FontSize="15" />
                    <Label x:Name="TitleLabel"
                           Text=""
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label x:Name="DescriptionLabel"
                           Text=""
                           Style="{StaticResource BodyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout x:Name="QuestionsContainer"
                                 Spacing="12" />

            <Button x:Name="SubmitButton"
                    Text=""
                    Style="{StaticResource PrimaryButtonStyle}"
                    Clicked="OnSubmitClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
