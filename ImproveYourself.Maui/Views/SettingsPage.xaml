<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ImproveYourself.Maui.Views.SettingsPage"
             BackgroundColor="{StaticResource ColorBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="22,16,22,30"
                             Spacing="16">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="ProfileSectionLabel"
                           Text=""
                           Style="{StaticResource SubtitleLabelStyle}" />
                    <Label x:Name="GreetingNameLabel"
                           Text=""
                           Style="{StaticResource BodyLabelStyle}" />

                    <Entry x:Name="NameEntry"
                           MaxLength="24"
                           Placeholder=""
                           PlaceholderColor="{StaticResource ColorTextSecondary}"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           TextColor="{StaticResource ColorTextPrimary}"
                           BackgroundColor="{StaticResource ColorFrame}"
                           HeightRequest="52" />

                    <Button x:Name="SaveNameButton"
                            Text=""
                            Style="{StaticResource PrimaryButtonStyle}"
                            Clicked="OnSaveNameClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="LanguageSectionLabel"
                           Text=""
                           Style="{StaticResource SubtitleLabelStyle}" />

                    <Grid ColumnDefinitions="*,Auto"
                          VerticalOptions="Center">
                        <Label x:Name="LanguageCurrentLabel"
                               Text=""
                               FontFamily="OpenSansRegular"
                               FontSize="15"
                               TextColor="{StaticResource ColorTextPrimary}"
                               VerticalTextAlignment="Center" />
                        <Button Grid.Column="1"
                                x:Name="LanguagePickerButton"
                                Text=""
                                Style="{StaticResource PrimaryButtonStyle}"
                                Clicked="OnLanguagePickerClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="RemindersSectionLabel"
                           Text=""
                           Style="{StaticResource SubtitleLabelStyle}" />
                    <Label x:Name="ReminderDescLabel"
                           Text=""
                           Style="{StaticResource BodyLabelStyle}"
                           LineBreakMode="WordWrap" />

                    <Grid ColumnDefinitions="*,Auto"
                          VerticalOptions="Center">
                        <Label x:Name="EnableNotificationsLabel"
                               Text=""
                               FontFamily="OpenSansRegular"
                               FontSize="15"
                               TextColor="{StaticResource ColorTextPrimary}"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1"
                                x:Name="NotificationSwitch"
                                OnColor="{StaticResource ColorAccent}"
                                ThumbColor="{StaticResource ColorTextPrimary}"
                                Toggled="OnNotificationToggled" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="OfflineFirstTitleLabel"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           TextColor="{StaticResource ColorAccent}" />
                    <Label x:Name="OfflineFirstDescLabel"
                           Text=""
                           Style="{StaticResource BodyLabelStyle}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="BackendSectionLabel"
                           Text=""
                           Style="{StaticResource SubtitleLabelStyle}" />
                    <Label x:Name="BackendDescLabel"
                           Text=""
                           Style="{StaticResource BodyLabelStyle}"
                           LineBreakMode="WordWrap" />

                    <Entry x:Name="BackendUrlEntry"
                           Placeholder="https://your-service.up.railway.app"
                           PlaceholderColor="{StaticResource ColorTextSecondary}"
                           Keyboard="Url"
                           FontFamily="OpenSansRegular"
                           FontSize="15"
                           TextColor="{StaticResource ColorTextPrimary}"
                           BackgroundColor="{StaticResource ColorFrame}"
                           HeightRequest="52" />

                    <Entry x:Name="BackendApiKeyEntry"
                           Placeholder="API key"
                           PlaceholderColor="{StaticResource ColorTextSecondary}"
                           IsPassword="True"
                           FontFamily="OpenSansRegular"
                           FontSize="15"
                           TextColor="{StaticResource ColorTextPrimary}"
                           BackgroundColor="{StaticResource ColorFrame}"
                           HeightRequest="52" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button x:Name="SaveBackendButton"
                                Text=""
                                Clicked="OnSaveBackendClicked" />
                        <Button Grid.Column="1"
                                x:Name="CheckBackendButton"
                                Text=""
                                Style="{StaticResource PrimaryButtonStyle}"
                                Clicked="OnCheckBackendClicked" />
                    </Grid>

                    <Label x:Name="BackendStatusLabel"
                           Style="{StaticResource BodyLabelStyle}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
