<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ImproveYourself.Maui.Views.ChallengeDetailPage"
             Title="Ежедневный вызов"
             BackgroundColor="{StaticResource ColorBackground}">
    <ScrollView>
              <ScrollView.GestureRecognizers>
                     <TapGestureRecognizer Tapped="OnScreenTapped" />
              </ScrollView.GestureRecognizers>
        <VerticalStackLayout Padding="22,16,22,30"
                             Spacing="16">
            <Border Style="{StaticResource CardBorderStyle}"
                    Padding="22">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="DateLabel"
                           Text="Дата: --"
                           Style="{StaticResource BodyLabelStyle}" />
                    <Label x:Name="ChallengeTitleLabel"
                           Text="Твой ежедневный вызов"
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label x:Name="ProgressLabel"
                           Text="Прогресс: 0/2"
                           Style="{StaticResource BodyLabelStyle}" />

                    <ProgressBar x:Name="ChallengeProgressBar"
                                 Progress="0"
                                 ProgressColor="{StaticResource ColorAccent}"
                                 BackgroundColor="{StaticResource ColorFrame}"
                                 HeightRequest="10" />

                    <Label x:Name="CompletedTextLabel"
                           Text="Вызов дня закрыт. Можно переходить к следующему дню."
                           TextColor="{StaticResource ColorSuccess}"
                           FontFamily="OpenSansRegular"
                           FontSize="15"
                           IsVisible="False" />

                    <Button x:Name="NextDayButton"
                            Text="Перейти к следующему дню"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsVisible="False"
                            Clicked="OnOpenNextDayClicked" />
                </VerticalStackLayout>
            </Border>

                     <Border x:Name="QuoteSectionBorder"
                                   Style="{StaticResource CardBorderStyle}"
                                   IsVisible="False"
                                   StrokeThickness="1.5">
                            <Border.GestureRecognizers>
                                   <TapGestureRecognizer Tapped="OnQuoteTapped" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="4,*"
                                     ColumnSpacing="14">
                                   <BoxView Color="{StaticResource ColorAccent}"
                                                  CornerRadius="2"
                                                  WidthRequest="4"
                                                  HorizontalOptions="Start"
                                                  VerticalOptions="Fill" />

                                   <VerticalStackLayout Grid.Column="1"
                                                                       Spacing="8">
                                          <Label Text="Цитата дня"
                                                    TextColor="{StaticResource ColorAccent}"
                                                    FontFamily="OpenSansRegular"
                                                    FontSize="15" />
                                          <Label x:Name="QuoteTextLabel"
                                                    Text=""
                                                    Style="{StaticResource SubtitleLabelStyle}"
                                                    LineBreakMode="WordWrap" />
                                          <Label x:Name="QuoteAuthorLabel"
                                                    Text=""
                                                    Style="{StaticResource BodyLabelStyle}"
                                                    IsVisible="False" />
                                          <Label x:Name="QuoteHintLabel"
                                                    Text="Нажми, чтобы открыть пояснение"
                                                    FontFamily="OpenSansRegular"
                                                    FontSize="13"
                                                    TextColor="{StaticResource ColorTextSecondary}"
                                                    IsVisible="False" />
                                   </VerticalStackLayout>
                            </Grid>
                     </Border>

                     <Border x:Name="QuoteNoteBorder"
                                   Style="{StaticResource CardBorderStyle}"
                                   IsVisible="False"
                                   Padding="18,16"
                                   Margin="20,-6,0,0">
                            <VerticalStackLayout Spacing="8">
                                   <Label Text="Пояснение"
                                             TextColor="{StaticResource ColorAccent}"
                                             FontFamily="OpenSansRegular"
                                             FontSize="14" />
                                   <Label x:Name="QuoteNoteLabel"
                                             Text=""
                                             Style="{StaticResource BodyLabelStyle}"
                                             TextColor="{StaticResource ColorTextPrimary}"
                                             LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                     </Border>

            <VerticalStackLayout x:Name="StepsContainer" Spacing="12" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
